# =============================================================================
# .env.example — template for the API keys this project needs
# =============================================================================
# HOW TO USE:
#   1. Copy this file to `.env` in the same folder:
#        copy .env.example .env       (Windows)
#        cp .env.example .env         (Mac/Linux)
#   2. Fill in your actual tokens (the .env file is gitignored — safe).
#   3. Our code loads these via python-dotenv on startup.
# =============================================================================


# --- HuggingFace Hub token ----------------------------------------------------
# Needed to:
#   - Download some models (Mistral-7B is gated — you must accept its license
#     on huggingface.co before downloading).
#   - Upload the final adapter / eval dataset to HuggingFace Hub.
# Get one at: https://huggingface.co/settings/tokens
# Use a "read" token for downloading, "write" token if you'll upload.
HF_TOKEN=hf_your_token_here


# --- OpenAI API key -----------------------------------------------------------
# Needed for the LLM-as-Judge evaluation: we ask GPT-4o-mini to rate each
# fine-tuned answer from 1-5 vs the reference answer.
# Cost: roughly $0.50-$1.00 for a full eval run of 50 questions.
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here


# --- Weights & Biases API key -------------------------------------------------
# Needed to log training runs to the W&B dashboard (loss curves, configs,
# eval metrics). Free for personal projects.
# Get one at: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_key_here

# Optional: W&B project name (groups all runs under one dashboard)
WANDB_PROJECT=llm-finetune-docker-qa
